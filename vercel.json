{
  "redirects": [
    { "source": "/backtest", "destination": "/backtest/", "statusCode": 301 },
    { "source": "/roadmap", "destination": "/roadmap/", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/backtest/", "destination": "/docs/backtest/index.html" },
    { "source": "/backtest/:path*", "destination": "/docs/backtest/:path*" },
    { "source": "/roadmap/", "destination": "/docs/roadmap/index.html" },
    { "source": "/roadmap/:path*", "destination": "/docs/roadmap/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
